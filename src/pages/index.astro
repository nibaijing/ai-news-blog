---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const others = posts.slice(1);
---
<BaseLayout title="Intelligence Hub">
	<h1>Intelligence Hub</h1>
	<p style="color: #94a3b8; margin-bottom: 4rem; font-size: 1.2rem;">Automated deep-dives into the frontiers of AI, Finance, and Global Power.</p>
	
	<div class="grid">
		{featured && (
			<a href={`/blog/${featured.slug}`} class="featured" style="text-decoration: none; color: inherit;">
				<div>
					<div class="post-meta">{featured.data.pubDate.toDateString()} • {featured.data.tags[0]}</div>
					<h2>{featured.data.title}</h2>
					<p style="font-size: 1.2rem; color: #aaa;">{featured.data.description}</p>
					<div style="margin-top: 2rem; font-weight: 800; color: #3b82f6; text-decoration: underline;">Read Intelligence $\rightarrow$</div>
				</div>
				<img src={featured.data.image} style="width: 100%; height: 400px; object-fit: cover; border-radius: 12px;" />
			</a>
		)}

		<div class="feed">
			{others.map(post => (
				<a href={`/blog/${post.slug}`} class="feed-item" style="text-decoration: none; color: inherit;">
					<div class="feed-content">
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
					</div>
					<div class="feed-meta">
						<div>{post.data.pubDate.toDateString()}</div>
						<div class="tags" style="margin-top: 0.5rem;">
							{post.data.tags.map(tag => <span class="tag">{tag}</span>)}
						</div>
					</div>
				</a>
			))}
		</div>
	</div>
</BaseLayout>
