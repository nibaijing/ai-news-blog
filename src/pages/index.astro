---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout title="AI News Factory | Intelligence Hub">
	<h1>Intelligence Hub</h1>
	<p style="color: #666; margin-bottom: 3rem;">Automated deep-dives into AI, Finance, and Current Events.</p>
	
	<div style="display: grid; gap: 2rem;">
		{posts.map(post => (
			<div style="border-bottom: 1px solid #eee; padding-bottom: 1.5rem;">
				<a href={`/blog/${post.slug}`} style="text-decoration: none; color: #000;">
					<h2 style="margin: 0 0 0.5rem 0;">{post.data.title}</h2>
				</a>
				<div class="post-meta">
					{post.data.pubDate.toDateString()} • {post.data.tags.join(', ')}
				</div>
				<p style="margin: 0;">{post.data.description}</p>
			</div>
		))}
	</div>
</BaseLayout>
