---
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | AI News Factory</title>
        <link rel="stylesheet" href="/src/styles/global.css" />
	</head>
	<body class="bg-slate-950 text-slate-200 font-sans selection:bg-blue-500 selection:text-white">
		<nav class="sticky top-0 z-50 backdrop-blur-md bg-slate-950/80 border-b border-slate-800 px-6 py-4">
			<div class="max-w-6xl mx-auto flex justify-between items-center">
				<a href="/" class="text-blue-500 font-black text-xl tracking-tighter uppercase">AI News Factory</a>
				<div class="hidden md:flex items-center gap-6">
					<span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest border-r border-slate-800 pr-6">Categories</span>
					<div class="flex gap-6">
						<a href="/" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">Home</a>
						<a href="/blog/tag/AI" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">AI</a>
						<a href="/blog/tag/Finance" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">Finance</a>
						<a href="/blog/tag/CurrentEvents" class="text-sm font-medium text-slate-400 hover:text-white transition-colors">Current Events</a>
					</div>
				</div>
			</div>
		</nav>
		<main class="max-w-6xl mx-auto px-6 py-12">
			<slot />
		</main>
	</body>
</html>
