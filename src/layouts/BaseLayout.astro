---
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | AI News Factory</title>
        <style>
            :root {
                --bg: #0f172a;
                --fg: #f1f5f9;
                --accent: #3b82f6;
                --accent-glow: rgba(59, 130, 246, 0.2);
                --muted: #94a3b8;
                --border: #1e293b;
                --card-bg: #1e293b;
            }
            body { 
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                line-height: 1.7;
                color: var(--fg);
                max-width: 1100px;
                margin: 0 auto;
                padding: 0 1.5rem;
                background-color: var(--bg);
                background-image: radial-gradient(circle at top right, var(--accent-glow), transparent 400px),
                                  radial-gradient(circle at bottom left, var(--accent-glow), transparent 400px);
                background-attachment: fixed;
            }
            nav { 
                position: sticky;
                top: 0;
                z-index: 100;
                display: flex; 
                justify-content: space-between; 
                align-items: center;
                padding: 1.2rem 0;
                margin-bottom: 4rem;
                backdrop-filter: blur(16px);
                background: rgba(15, 23, 42, 0.9);
                border-bottom: 1px solid var(--border);
            }
            .logo { 
                font-weight: 900; 
                font-size: 1.1rem; 
                letter-spacing: -0.05em;
                text-transform: uppercase;
                text-decoration: none; 
                color: var(--accent); 
            }
            .nav-container {
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }
            .category-label {
                font-size: 0.7rem;
                font-weight: 800;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: 0.1em;
                border-right: 1px solid var(--border);
                padding-right: 1.5rem;
            }
            .nav-links { 
                display: flex; 
                gap: 1.2rem; 
            }
            .nav-links a { 
                text-decoration: none; 
                color: var(--muted); 
                font-size: 0.85rem; 
                font-weight: 500; 
                transition: all 0.3s ease;
                padding: 0.3rem 0.6rem;
                border-radius: 4px;
            }
            .nav-links a:hover { 
                color: var(--accent); 
                background: rgba(59, 130, 246, 0.1);
            }
            h1, h2, h3 { 
                color: var(--fg); 
                font-weight: 800; 
                line-height: 1.1; 
                margin-bottom: 1rem;
                letter-spacing: -0.02em;
            }
            h1 { font-size: 3.5rem; }
            .post-meta { color: var(--muted); font-size: 0.85rem; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: 0.1em; }
            .content { 
                font-size: 1.2rem; 
                max-width: 700px; 
                margin: 0 auto; 
            }
            .content p { margin-bottom: 1.5rem; }
            .tag { 
                display: inline-block; 
                border: 1px solid var(--border);
                padding: 0.2rem 0.6rem; 
                border-radius: 4px; 
                font-size: 0.75rem; 
                margin-right: 0.5rem;
                color: var(--muted);
                background: rgba(255,255,255,0.05);
            }
            .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem; }
            .card { 
                background: var(--card-bg); 
                border: 1px solid var(--border); 
                padding: 2rem; 
                transition: all 0.3s ease;
                text-decoration: none;
                color: inherit;
                display: block;
                border-radius: 12px;
            }
            .card:hover { 
                border-color: var(--accent); 
                transform: translateY(-5px);
                box-shadow: 0 10px 30px -10px var(--accent-glow);
            }
            .card h3 { margin: 0 0 1rem 0; font-size: 1.5rem; }
            .card p { color: var(--muted); font-size: 1rem; margin-bottom: 1.5rem; }
            .featured { 
                grid-column: 1 / -1; 
                display: grid; 
                grid-template-columns: 1fr 1fr; 
                gap: 3rem; 
                align-items: center;
                border: 1px solid var(--border);
                padding: 3rem;
                background: var(--card-bg);
                margin-bottom: 4rem;
                border-radius: 24px;
                overflow: hidden;
            }
            @media (max-width: 768px) {
                .featured { grid-template-columns: 1fr; }
                h1 { font-size: 2.5rem; }
                .nav-container {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 0.8rem;
                }
                .category-label {
                    border-right: none;
                    padding-right: 0;
                    margin-bottom: 0.2rem;
                }
                .nav-links {
                    display: flex;
                    flex-wrap: wrap;
                }
                nav {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 1rem;
                }
            }
        </style>
	</head>
	<body>
		<nav>
			<a href="/" class="logo">AI NEWS FACTORY</a>
			<div class="nav-container">
				<div class="category-label">Categories</div>
				<div class="nav-links">
					<a href="/">Home</a>
					<a href="/blog/tag/AI">AI</a>
					<a href="/blog/tag/Finance">Finance</a>
					<a href="/blog/tag/CurrentEvents">Current Events</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>
