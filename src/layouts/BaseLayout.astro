---
interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
        <style>
            body { 
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                line-height: 1.6;
                color: #333;
                max-width: 800px;
                margin: 0 auto;
                padding: 2rem 1rem;
                background-color: #fdfdfd;
            }
            nav { margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: center; }
            .logo { font-weight: 800; font-size: 1.5rem; text-decoration: none; color: #000; }
            h1 { font-size: 3rem; font-weight: 900; line-height: 1.1; margin-bottom: 1rem; }
            .post-meta { color: #666; font-size: 0.9rem; margin-bottom: 2rem; }
            .content { font-size: 1.1rem; }
            .tag { 
                display: inline-block; 
                background: #eee; 
                padding: 0.2rem 0.6rem; 
                border-radius: 4px; 
                font-size: 0.8rem; 
                margin-right: 0.5rem;
            }
        </style>
	</head>
	<body>
		<nav>
			<a href="/" class="logo">AI NEWS FACTORY</a>
		</nav>
		<slot />
	</body>
</html>
